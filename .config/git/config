[alias]
	ca = commit -a
	fire = commit -am 'Fire!!!' && push
	pl = pull
	ps = push
	s = status
[commit]
	gpgSign = true
[merge]
	tool = vimdiff
	conflictStyle = diff3
[mergetool "vimdiff"]
	cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
