super + Return
  $TERMINAL & disown

super + d
  dmenu_run & disown

super + e
  $TERMINAL -e $MAIL & disown

super + q
  xdotool windowkill "$(xdotool getactivewindow)"

super + r
  $TERMINAL -e $FILE & disown

super + shift + p
  emacsclient -c & disown

super + w
  $BROWSER & disown

super + x
  $LOCK_CMD & disown

