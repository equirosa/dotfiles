super + Return
  $TERMINAL & disown

super + d
  dmenu_run

super + e
  $TERMINAL -e $MAIL

super + i
      $TERMINAL -e htop

super + r
  $TERMINAL -e $FILE

super + w
  $BROWSER

super + q
  xdotool windowkill "$(xdotool getactivewindow)"

super + x
  $LOCKSCREEN

super + shift + p
      emacsclient -c