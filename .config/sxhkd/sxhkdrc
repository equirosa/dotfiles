super + Return
  $TERMINAL & disown

super + d
  dmenu_run & disown

super + i
	$TERMINAL -e $MONITOR & disown

super + e
  $TERMINAL -e $MAIL & disown

super + q
  xdotool windowkill "$(xdotool getactivewindow)"

super + r
  $TERMINAL -e $FILE & disown

super + shift + p
  emacsclient -c & disown

super + w
	tor-browser

super + shift + w
  $BROWSER & disown

super + x
	i3lock-fancy -p & disown
