{
	/*"height": 10,*/
	"layer": "top",
	"modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
	"modules-center": [],
	"modules-right": ["custom/layout","network","pulseaudio","backlight","memory","battery","clock","idle_inhibitor","tray"],
	"sway/window": {
		"format": "{}",
		"tooltip": false
	},
	"custom/layout": {
		"on-click": "",
		"interval": 1,
		"exec": "sway-keyboard-layout",
		"format": "{}"
	},
	"custom/torrent": {
		"on-click": "$TERMINAL -e stig",
		"exec-if": "pgrep transmission-da",
		"interval": 10,
		"exec": "torrent",
		"format": "{}"
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-bluetooth": "{volume}% {icon}яКФ",
		"format-muted": "яАж",
		"format-iconts": {
			"headphones": "яАе",
			"handsfree": "яЦР",
			"headset": "яЦР",
			"phone": "яВХ",
			"portable": "яВХ",
			"car": "яЖ╣",
			"default": ["яАз", "яАи"]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol"
	},
	"network": {
		"on-click" : "$TERMINAL -e nmtui",
		"interval": 30,
		"format-ethernet": "{bandwidthDownBits} яБг {bandwidthUpBits} яБв {icon}",
		"format-wifi": "{essid} {signalStrength}% {icon}",
		"format-disconnected": "{icon}",
		"format-icons": {
            "wifi": ["яки"],
            "ethernet": ["яЫ┐"],
            "disconnected": ["якй"]
        }
	},
	"memory": {
		"interval": 30,
		"format": "{percentage}% ябЪ "
	},
	"battery": {
		"format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "],
		"format-charging": "{capacity}% {icon}",
		"format": "{capacity}% {icon}",
		"format-full": "{icon}",
		"states": {
			  "critical": 10,
			  "warning": 30
		}
	},
	"clock": {
		"interval": 10,
		"format": "{:яБ│ %Y/%m/%d - %a - яАЧ %R}"
	},
	"tray": {
		"icon-size": 18
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "{percent}% {icon}",
		"format-icons": ["яЧЭ ", "яЧЮ ", "яЧЯ "]
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "яБо ",
			"deactivated": "яБ░ "
		}
	}

}
