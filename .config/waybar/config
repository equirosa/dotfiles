{
  /*"height": 10,*/
  "layer": "top",
  "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
  "modules-center": [],
  "modules-right": [
    "custom/layout",
    "network",
    "mpd",
    "pulseaudio",
    "backlight",
    "memory",
    "battery",
    "clock",
    "idle_inhibitor",
    "tray"
  ],
  "sway/window": {
    "format": "{}",
    "tooltip": false
  },
  "custom/layout": {
    "on-click": "",
    "interval": 1,
    "exec": "sway-keyboard-layout",
    "format": "яДЬ {}"
  },
  "custom/torrent": {
    "on-click": "$TERMINAL -e stig",
    "exec-if": "pgrep transmission-da",
    "interval": 10,
    "exec": "torrent",
    "format": "{}"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}яКФ",
    "format-muted": "яАж",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАз", "яАи"]
    },
    "scroll-step": 1,
    "on-click": "pulsemixer"
  },
  "network": {
    "on-click": "$TERMINAL -e nmtui",
    "interval": 30,
    "format-ethernet": "{bandwidthDownBits} яБг {bandwidthUpBits} яБв {icon}",
    "format-wifi": "{essid} {signalStrength}% {icon}",
    "format-disconnected": "{icon}",
    "format-icons": {
      "wifi": ["яки"],
      "ethernet": ["яЫ┐"],
      "disconnected": ["якй"]
    }
  },
  "memory": {
    "interval": 30,
    "format": "{percentage}% ябЪ ",
    "on-click": "$TERMINAL -e gotop"
  },
  "battery": {
    "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "],
    "format-charging": "{capacity}% {icon}",
    "format": "{capacity}% {icon}",
    "format-full": "{icon}",
    "states": {
      "critical": 10,
      "warning": 30
    }
  },
  "clock": {
    "interval": 10,
    "format": "{:яБ│ %Y/%m/%d - %a - яАЧ %R}"
  },
  "tray": {
    "icon-size": 18
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["яЧЭ ", "яЧЮ ", "яЧЯ "]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо ",
      "deactivated": "яБ░ "
    }
  },
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {title} {elapsedTime:%M:%S} яАБ",
    "format-disconnected": "Disconnected яАБ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
    "interval": 1,
    "consume-icons": {
      "on": "яГД "
    },
    "random-icons": {
      "off": "",
      "on": "яБ┤ "
    },
    "repeat-icons": {
      "on": "яАЮ "
    },
    "single-icons": {
      "on": "яАЮ1 "
    },
    "state-icons": {
      "paused": "яБМ",
      "playing": "яБЛ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  }
}
