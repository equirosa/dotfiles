{
	"layer": "top",
	"modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
	"modules-center": [],
	"modules-right": ["custom/torrent","network","pulseaudio","backlight","memory","battery","clock","idle_inhibitor","tray"],
	"sway/window": {
		"format": "{}",
		"tooltip": false
	},
	"custom/torrent": {
		"on-click": "$TERMINAL -e transmission-remote-cli",
		"exec-if": "pgrep transmission-da",
		"interval": 10,
		"exec": "torrent",
		"format": "{}"
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-bluetooth": "{volume}% {icon}ΎΛΦ",
		"format-muted": "ΎΑο",
		"format-iconts": {
			"headphones": "ΎΑξ",
			"handsfree": "ΎΨΡ",
			"headset": "ΎΨΡ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑπ", "ΎΑρ"]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol"
	},
	"network": {
		"on-click" : "$TERMINAL -e nmtui",
		"interval": 30,
		"format-ethernet": "{icon}",
		"format-wifi": "{essid} {signalStrength}% {icon}",
		"format-disconnected": "{icon}",
		"format-icons": {
            "wifi": ["Ύγς", "Ύγτ" ,"ΎΘτ"],
            "ethernet": ["Ύδ┐"],
            "disconnected": ["Ύγυ"]
        }
	},
	"memory": {
		"interval": 30,
		"format": "{percentage}% Ύκγ"
	},
	"battery": {
		"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
		"format-charging": "{capacity}% ΎΩπ",
		"format": "{capacity}% {icon}",
		"format-full": "{icon}",
		"states": {
			  "critical": 10
		}
	},
	"clock": {
		"interval": 5,
		"format": "{:ΎΑΩ %H:%M}"
	},
	"tray": {
		"icon-size": 18
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "{percent}% {icon}",
		"format-icons": ["ΎΗΖ", "ΎΕΣ"]
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "ΎΒχ",
			"deactivated": "ΎΒ░"
		}
	}

}
