#!/bin/sh

case "$1" in
	*.mp4 | *.webm | *.mkv) exec umpv "$1" & disown ;;
	*.pdf) exec zathura "$1" & disown;;
	*invidio.us* | *youtube.com*) exec umpv --ytdl=yes "$1" & disown	;;
	http* | https* )
		case "$1" in
			*.jpg | *.png) curl "$1" -o "/tmp/image" && $IMG "/tmp/image" & disown ;;
			*) "$BROWSER" "$1" ;;
		esac;;
	*.jpg | *.png) "$IMG $1" & disown ;;
	mailto*)	exec aerc "$1" ;;
	*.html) exec "$BROWSER" "$1" ;;
	*)  exec /run/current-system/sw/bin/xdg-open "$1" ;;
esac
